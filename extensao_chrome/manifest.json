{
  "manifest_version": 3,
  "name": "Tiao Cards → CLIPP",
  "version": "1.6.5",
  "description": "Importa o pedido aberto no painel para o CLIPP (Chrome em que você já está logado).",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "https://www.tiaocards.com.br/*",
    "https://www.ligamagic.com.br/*",
    "http://127.0.0.1/*"
  ],
  "action": {
    "default_title": "Importar pedido para CLIPP",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["relatorio.html", "relatorio.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
